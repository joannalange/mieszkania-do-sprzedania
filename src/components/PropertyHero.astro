---
const { title, address, price, image } = Astro.props;
---
<section class="relative h-[80vh] min-h-[600px] flex items-end overflow-hidden">
  <img 
    src={image} 
    alt={title} 
    class="absolute inset-0 w-full h-full object-cover z-0 grayscale-[20%] brightness-75 transition-transform duration-1000 hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
  
  <div class="relative z-20 max-w-7xl mx-auto px-6 pb-16 w-full">
    <div class="max-w-3xl">
      <span class="inline-block px-3 py-1 bg-white/20 backdrop-blur-md text-white text-sm tracking-widest uppercase mb-4 border border-white/30 rounded">
        Na Sprzedaż • Bezpośrednio
      </span>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 tracking-tight leading-tight">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-white/90 mb-8 font-light italic">
        {address}
      </p>
      <div class="flex flex-col md:flex-row gap-6 items-start md:items-center">
        <div class="bg-indigo-600 px-6 py-4 rounded-sm text-white shadow-2xl">
          <p class="text-xs uppercase tracking-widest opacity-80 mb-1">Cena ofertowa</p>
          <p class="text-3xl font-bold leading-none">{price}</p>
        </div>
        <a href="#contact" class="px-8 py-4 bg-white text-black font-bold hover:bg-slate-100 transition-colors rounded-sm uppercase tracking-wide">
          Umów prezentację
        </a>
      </div>
    </div>
  </div>
</section>
