---
const { description, features } = Astro.props;
---
<section class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      
      <div class="lg:col-span-7">
        <h2 class="text-xs uppercase tracking-widest text-indigo-600 font-bold mb-6">O Nieruchomości</h2>
        <p class="text-3xl font-medium text-slate-900 mb-10 leading-snug">
          {description.intro}
        </p>
        
        <div class="space-y-12">
          {description.sections.map((section) => (
            <div>
              <h3 class="text-xl font-bold text-slate-900 mb-4">{section.title}</h3>
              <p class="text-lg text-slate-600 leading-relaxed max-w-2xl">
                {section.content}
              </p>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="bg-white p-10 shadow-sm border border-slate-200">
          <h3 class="text-xl font-bold text-slate-900 mb-8">Kluczowe Atuty</h3>
          <ul class="space-y-4">
            {features.map((feature) => (
              <li class="flex items-start gap-4 text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-indigo-600 shrink-0">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="text-lg leading-tight">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>
